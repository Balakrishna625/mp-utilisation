'use client'

import { useState, useEffect, useMemo } from 'react'
import { useRouter } from 'next/navigation'
import { User, TrendingUp, Users, BarChart3, Upload } from 'lucide-react'
import { useAuth } from '@/contexts/AuthContext'
import { storageService } from '@/lib/storage'
import type { EmployeeUtilization } from '@/types/utilization'
import LoadingSkeleton from '@/components/LoadingSkeleton'
import LastUpdated from '@/components/LastUpdated'

export default function IndividualDashboard() {
  const { user, isAuthenticated } = useAuth()
  const router = useRouter()
  const [data, setData] = useState<EmployeeUtilization[]>([])
  const [loading, setLoading] = useState(true)
  const [lastUpdated, setLastUpdated] = useState<string | null>(null)

  useEffect(() => {
    if (!isAuthenticated || user?.role !== 'individual') {
      router.push('/login')
      return
    }
    loadData()

    // Listen for data updates
    const handleDataUpdate = () => loadData()
    window.addEventListener('utilizationDataUpdated', handleDataUpdate)
    
    return () => {
      window.removeEventListener('utilizationDataUpdated', handleDataUpdate)
    }
  }, [isAuthenticated, user, router])

  const loadData = () => {
    setLoading(true)
    setTimeout(() => {
      const storedData = storageService.getData()
      const metadata = storageService.getMetadata()
      setData(storedData)
      setLastUpdated(metadata?.lastUpdated || null)
      setLoading(false)
    }, 200)
  }

  // Filter data for individual user
  const { myData, menteeData } = useMemo(() => {
    if (!user?.employeeName) {
      return { myData: null, menteeData: [] }
    }

    // Find user's own data
    const myData = data.find(emp => emp.name === user.employeeName) || null

    // Find mentees (employees where mentor matches user's name)
    const menteeData = data.filter(emp => emp.mentor === user.employeeName)

    return { myData, menteeData }
  }, [data, user])

  if (loading) {
    return <LoadingSkeleton />
  }

  if (!myData) {
    return (
      <div className="min-h-screen bg-background p-6">
        <div className="max-w-4xl mx-auto">
          <div className="bg-surface border border-surface-light rounded-xl p-12 text-center">
            <Upload className="w-16 h-16 text-text-muted mx-auto mb-4" />
            <h2 className="text-xl font-semibold text-text-primary mb-2">No Data Available</h2>
            <p className="text-text-muted">
              No utilization data found for your profile. Please contact your manager.
            </p>
          </div>
        </div>
      </div>
    )
  }

  const getUtilizationColor = (utilization: number) => {
    if (utilization >= 90) return 'text-success'
    if (utilization >= 70) return 'text-warning'
    return 'text-danger'
  }

  const getUtilizationBgColor = (utilization: number) => {
    if (utilization >= 90) return 'bg-success/10'
    if (utilization >= 70) return 'bg-warning/10'
    return 'bg-danger/10'
  }

  return (
    <div className="min-h-screen bg-background p-6">
      <div className="max-w-7xl mx-auto space-y-6">
        {/* Header */}
        <div className="flex items-center justify-between">
          <div>
            <h1 className="text-3xl font-bold text-text-primary mb-2">
              Welcome, {user?.name}
            </h1>
            <p className="text-text-muted">Your utilization dashboard</p>
          </div>
          <LastUpdated timestamp={lastUpdated} />
        </div>

        {/* Personal Stats */}
        <div className="grid grid-cols-1 md:grid-cols-4 gap-6">
          <div className="bg-surface border border-surface-light rounded-xl p-6">
            <div className="flex items-center justify-between mb-2">
              <span className="text-text-muted text-sm">Utilization</span>
              <TrendingUp className="w-5 h-5 text-primary" />
            </div>
            <div className={`text-3xl font-bold ${getUtilizationColor(myData.utilization)}`}>
              {myData.utilization.toFixed(2)}%
            </div>
          </div>

          <div className="bg-surface border border-surface-light rounded-xl p-6">
            <div className="flex items-center justify-between mb-2">
              <span className="text-text-muted text-sm">Target Hours</span>
              <BarChart3 className="w-5 h-5 text-primary" />
            </div>
            <div className="text-3xl font-bold text-text-primary">
              {myData.targetHours}
            </div>
          </div>

          <div className="bg-surface border border-surface-light rounded-xl p-6">
            <div className="flex items-center justify-between mb-2">
              <span className="text-text-muted text-sm">Project Hours</span>
              <BarChart3 className="w-5 h-5 text-primary" />
            </div>
            <div className="text-3xl font-bold text-text-primary">
              {myData.project}
            </div>
          </div>

          <div className="bg-surface border border-surface-light rounded-xl p-6">
            <div className="flex items-center justify-between mb-2">
              <span className="text-text-muted text-sm">Mentees</span>
              <Users className="w-5 h-5 text-primary" />
            </div>
            <div className="text-3xl font-bold text-text-primary">
              {menteeData.length}
            </div>
          </div>
        </div>

        {/* Personal Details */}
        <div className="bg-surface border border-surface-light rounded-xl p-6">
          <h2 className="text-xl font-bold text-text-primary mb-6">Your Details</h2>
          <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <div>
              <label className="text-sm text-text-muted">Name</label>
              <p className="text-text-primary font-medium mt-1">{myData.name}</p>
            </div>
            <div>
              <label className="text-sm text-text-muted">Title</label>
              <p className="text-text-primary font-medium mt-1">{myData.title}</p>
            </div>
            <div>
              <label className="text-sm text-text-muted">Email</label>
              <p className="text-text-primary font-medium mt-1">{myData.email || 'N/A'}</p>
            </div>
            <div>
              <label className="text-sm text-text-muted">Fringe</label>
              <p className="text-text-primary font-medium mt-1">{myData.fringe}</p>
            </div>
            <div>
              <label className="text-sm text-text-muted">W/Presales</label>
              <p className="text-text-primary font-medium mt-1">{myData.wPresales.toFixed(2)}%</p>
            </div>
            <div>
              <label className="text-sm text-text-muted">Mentor</label>
              <p className="text-text-primary font-medium mt-1">{myData.mentor || 'No mentor assigned'}</p>
            </div>
          </div>
        </div>

        {/* Mentees Section */}
        {menteeData.length > 0 && (
          <div className="bg-surface border border-surface-light rounded-xl p-6">
            <h2 className="text-xl font-bold text-text-primary mb-6 flex items-center gap-2">
              <Users className="w-6 h-6 text-primary" />
              Your Mentees ({menteeData.length})
            </h2>
            <div className="overflow-x-auto">
              <table className="w-full">
                <thead>
                  <tr className="border-b border-surface-light">
                    <th className="text-left py-3 px-4 text-sm font-semibold text-text-muted">Name</th>
                    <th className="text-left py-3 px-4 text-sm font-semibold text-text-muted">Title</th>
                    <th className="text-right py-3 px-4 text-sm font-semibold text-text-muted">Target Hours</th>
                    <th className="text-right py-3 px-4 text-sm font-semibold text-text-muted">Project Hours</th>
                    <th className="text-right py-3 px-4 text-sm font-semibold text-text-muted">Utilization</th>
                  </tr>
                </thead>
                <tbody>
                  {menteeData.map((mentee) => (
                    <tr key={mentee.id} className="border-b border-surface-light/50 hover:bg-surface-light/30 transition-colors">
                      <td className="py-4 px-4">
                        <div className="flex items-center gap-3">
                          <div className="w-8 h-8 rounded-full bg-primary/10 flex items-center justify-center">
                            <User className="w-4 h-4 text-primary" />
                          </div>
                          <span className="font-medium text-text-primary">{mentee.name}</span>
                        </div>
                      </td>
                      <td className="py-4 px-4 text-text-muted">{mentee.title}</td>
                      <td className="py-4 px-4 text-right text-text-primary font-mono">{mentee.targetHours}</td>
                      <td className="py-4 px-4 text-right text-text-primary font-mono">{mentee.project}</td>
                      <td className="py-4 px-4 text-right">
                        <span className={`inline-flex items-center px-3 py-1 rounded-full text-sm font-semibold ${getUtilizationBgColor(mentee.utilization)} ${getUtilizationColor(mentee.utilization)}`}>
                          {mentee.utilization.toFixed(2)}%
                        </span>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        )}

        {menteeData.length === 0 && (
          <div className="bg-surface border border-surface-light rounded-xl p-12 text-center">
            <Users className="w-16 h-16 text-text-muted mx-auto mb-4" />
            <h3 className="text-lg font-semibold text-text-primary mb-2">No Mentees</h3>
            <p className="text-text-muted">
              You don't have any mentees assigned at the moment.
            </p>
          </div>
        )}
      </div>
    </div>
  )
}
