# ===========================================
# DATABASE CONFIGURATION
# ===========================================
# 
# Copy this file to .env and fill in your credentials
# ===========================================

# OPTION 1: SUPABASE (Development - Free Tier)
# Get from: Supabase Project Settings → Database → Connection Pooling → URI
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-us-west-1.pooler.supabase.com:6543/postgres"

# Optional: Direct connection for migrations
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-us-west-1.compute-1.amazonaws.com:5432/postgres"

# OPTION 2: AWS RDS (Production)
# DATABASE_URL="postgresql://postgres:[PASSWORD]@your-rds-endpoint.rds.amazonaws.com:5432/mp_utilization"

# ===========================================
# MIGRATION GUIDE: Supabase → AWS RDS
# ===========================================
# 
# 1. Export Supabase data:
#    npx prisma db push --skip-generate
#    pg_dump [SUPABASE_URL] > backup.sql
# 
# 2. Create AWS RDS PostgreSQL instance
# 
# 3. Update DATABASE_URL above with RDS endpoint
# 
# 4. Import data to RDS:
#    psql [RDS_URL] < backup.sql
# 
# 5. Run migrations:
#    npx prisma migrate deploy
# 
# That's it! Zero code changes needed.
# ===========================================
